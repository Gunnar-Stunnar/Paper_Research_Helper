# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── OpenAI ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini          # or gpt-4o, gpt-4-turbo, etc.

# ── Anthropic Claude (direct API) ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-5    # or claude-opus-4-5, claude-haiku-3-5
CLAUDE_MAX_TOKENS=4096
CLAUDE_TEMPERATURE=0

# ── AWS Bedrock ───────────────────────────────────────────────────────────
# Credentials: uses standard boto3 chain (env vars → ~/.aws/credentials → IAM role)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=                 # Only needed for temporary STS credentials
AWS_PROFILE=                       # Named profile from ~/.aws/credentials
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20251101-v1:0
BEDROCK_MAX_TOKENS=4096
BEDROCK_TEMPERATURE=0

# ── Semantic Scholar (optional — removes rate limiting) ────────────────────
SEMANTIC_SCHOLAR_API_KEY=

# ── Vector store ──────────────────────────────────────────────────────────
# FAISS (local file-based, default)
VECTORSTORE_PATH=data/vectorstore

# ── Local PostgreSQL + pgvector ───────────────────────────────────────────
# docker run -d --name pgvector -e POSTGRES_PASSWORD=postgres \
#   -p 5432:5432 pgvector/pgvector:pg16
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=paper_research
PG_COLLECTION=papers

# ── AWS Aurora PostgreSQL + pgvector ──────────────────────────────────────
AURORA_HOST=                        # e.g. my-cluster.cluster-abc.us-east-1.rds.amazonaws.com
AURORA_PORT=5432
AURORA_USER=                        # DB username (must have rds-db:connect IAM permission)
AURORA_PASSWORD=                    # Leave empty when using IAM auth
AURORA_DATABASE=paper_research
AURORA_COLLECTION=papers
AURORA_USE_IAM=false                # Set to 'true' to use IAM token auth instead of password
AWS_REGION=us-east-1               # Region used to generate IAM auth tokens

# ── LangSmith tracing (optional) ─────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=paper-research-helper
